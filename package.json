{
  "name": "snapit",
  "version": "2.0.0",
  "description": "Local QA tool — Lightshot-style screenshots, recording, and live session analysis",
  "main": "./out/main/index.js",
  "author": "Karan Trehan",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icon": "electron tools/make-icon.cjs",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "gifenc": "^1.0.3",
    "konva": "^10.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.10"
  },
  "volta": {
    "node": "22.22.3"
  }
}
